{
  "name": "graduados-app",
  "version": "1.1.4",
  "private": true,
  "scripts": {
    "serve": "vite",
    "build": "vite build",
    "postbuild": "node -e \"require('fs').copyFileSync('dist/index.html','dist/404.html')\"",
    "build:native": "cross-env CAPACITOR_BUILD=1 vite build",
    "ota:build": "npm run build:native && node tools/ota/make-bundle.js",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "ionic:build": "cross-env CAPACITOR_BUILD=1 vite build",
    "ionic:serve": "vite",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "lint": "eslint . --ext .vue,.js,.ts --ignore-path .gitignore",
    "type-check": "tsc --noEmit",
    "deploy": "gh-pages -d dist"
  },
  "engines": {
    "node": ">=22"
  },
  "homepage": "https://BOOTCOOP.github.io/APP-GRADUADOS",
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/app": "^7.0.0",
    "@capacitor/camera": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/filesystem": "^7.0.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/keyboard": "^7.0.0",
    "@capacitor/share": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0",
    "@capgo/capacitor-updater": "^7.50.1",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/vue-fontawesome": "^3.0.8",
    "@ionic/storage": "^4.0.0",
    "@ionic/vue": "^6.0.0",
    "@ionic/vue-router": "^6.0.0",
    "@vee-validate/i18n": "^4.8.3",
    "@vee-validate/rules": "^4.8.4",
    "axios": "^1.3.4",
    "ionicons": "^6.0.3",
    "pinia": "^3.0.0",
    "swiper": "^12.2.0",
    "vee-validate": "^4.8.4",
    "vue": "^3.5.13",
    "vue-router": "^4.0.12",
    "vue-virtual-scroller": "^2.0.0-beta.8",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@types/node": "^22.20.1",
    "@typescript-eslint/eslint-plugin": "^5.6.0",
    "@typescript-eslint/parser": "^5.6.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^11.0.2",
    "@vue/test-utils": "^2.0.0-rc.16",
    "adm-zip": "^0.5.18",
    "autoprefixer": "^10.5.2",
    "cross-env": "^10.1.0",
    "eslint": "^8.4.1",
    "eslint-plugin-vue": "^9.8.0",
    "gh-pages": "^6.3.0",
    "jsdom": "^29.1.1",
    "typescript": "^4.3.5",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "description": "An Ionic project"
}
