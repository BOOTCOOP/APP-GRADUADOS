# OJO: el valor de VITE_APPLICATION_NAME deriva las claves de localStorage.
# Cambiarlo desloguea a todos los usuarios — no tocar.
VITE_APPLICATION_NAME=graduados

# Producción
VITE_API_URL=https://graduados.derecho.uba.ar/api

# Para desarrollo local - WEB (usa localhost)
# VITE_API_URL=http://localhost:8000/api
# VITE_API_URL=http://127.0.0.1:8000/api

# Para desarrollo local - MOBILE (necesita IP real de la red)
# Reemplaza 192.168.1.XXX con tu IP real
# VITE_API_URL=http://192.168.1.155:8000/api
