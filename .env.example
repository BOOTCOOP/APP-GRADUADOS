# Copiar a .env:  cp .env.example .env

# OJO: el valor de VITE_APPLICATION_NAME deriva las claves de localStorage.
# Cambiarlo desloguea a todos los usuarios — no tocar.
VITE_APPLICATION_NAME=graduados

# Base de la API (incluye /api). Producción:
VITE_API_URL=https://graduados.derecho.uba.ar/api

# Para desarrollo local - WEB (usa localhost)
# VITE_API_URL=http://localhost:8000/api
# VITE_API_URL=http://127.0.0.1:8000/api

# Para desarrollo local - MOBILE (necesita la IP real de tu máquina en la red)
# VITE_API_URL=http://192.168.1.XXX:8000/api

# Solo para pruebas del ciclo OTA en device: apunta el chequeo de updates a un
# manifiesto alternativo (por defecto usa el latest.json real de GitHub Pages).
# VITE_OTA_MANIFEST_URL=http://192.168.1.XXX:8081/latest.json
